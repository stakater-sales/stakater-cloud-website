---
import { footerLinks, compareLinks } from '../../data/navigation';
---
<footer class="bg-purple-dark text-white/70">
  <div class="container-site pt-[72px] pb-10">
    <!-- Grid: brand (2 cols) + 4 link groups = 6 cols -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-12 mb-16">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center no-underline mb-4" aria-label="Stakater Cloud">
          <img src="/images/logo-white.svg" alt="Stakater Cloud" class="h-7 w-auto" />
        </a>
        <p class="text-[14px] leading-relaxed text-white/50 max-w-[280px] mb-6">
          Managed OpenShift hosted in Europe. Operated by Red Hat Premier Partners. Production-ready in under 15 minutes.
        </p>
        <!-- Socials -->
        <div class="flex gap-3">
          <!-- GitHub -->
          <a
            href="https://github.com/stakater"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="w-9 h-9 rounded-lg bg-white/[0.08] flex items-center justify-center hover:bg-orange hover:text-white transition-all duration-150 no-underline"
          >
            <svg class="w-[18px] h-[18px] fill-current text-white/60 hover:text-white" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.341-3.369-1.341-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.934.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
            </svg>
          </a>
          <!-- LinkedIn -->
          <a
            href="https://www.linkedin.com/company/stakater"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="w-9 h-9 rounded-lg bg-white/[0.08] flex items-center justify-center hover:bg-orange hover:text-white transition-all duration-150 no-underline"
          >
            <svg class="w-[18px] h-[18px] fill-current text-white/60" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <!-- X / Twitter -->
          <a
            href="https://twitter.com/stakater"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="X / Twitter"
            class="w-9 h-9 rounded-lg bg-white/[0.08] flex items-center justify-center hover:bg-orange hover:text-white transition-all duration-150 no-underline"
          >
            <svg class="w-[16px] h-[16px] fill-current text-white/60" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Link Columns -->
      {Object.entries(footerLinks).map(([group, links]) => (
        <div>
          <h6 class="text-[11px] font-bold uppercase tracking-[1.5px] text-white/40 mb-5">{group}</h6>
          <ul class="list-none m-0 p-0 flex flex-col gap-2.5">
            {links.map(link => (
              <li>
                <a
                  href={link.href}
                  class="text-[14px] text-white/60 no-underline hover:text-orange transition-colors duration-150"
                  target={link.href.startsWith('http') ? '_blank' : undefined}
                  rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Compare row -->
    <div class="py-5 border-t border-white/[0.08] border-b border-white/[0.08]">
      <div class="flex items-center gap-2 flex-wrap">
        <span class="text-[11px] font-bold uppercase tracking-widest text-white/30 mr-2">Compare</span>
        <span class="text-white/[0.15] text-[13px]">|</span>
        {compareLinks.map((l, i) => (
          <>
            {i > 0 && <span class="text-white/[0.15] text-[13px]">·</span>}
            <a href={l.href} class="text-[13px] text-white/40 no-underline hover:text-orange transition-colors duration-150">{l.label}</a>
          </>
        ))}
      </div>
    </div>

    <!-- Bottom -->
    <div class="pt-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <div class="text-[12px] text-white/30 flex flex-wrap items-center gap-x-3 gap-y-1">
        <span>© {new Date().getFullYear()} Stakater Cloud · Stakater AB Sweden · Org # 559066-6870</span>
        <span class="hidden sm:inline text-white/[0.15]">·</span>
        <a href="/privacy" class="text-white/40 hover:text-orange transition-colors no-underline">Privacy Policy</a>
      </div>
      <div class="flex gap-2 flex-wrap">
        {['ISO 27001', 'ISO 9001', 'RH Premier Partner', 'GDPR Ready'].map(cert => (
          <span class="bg-white/[0.06] border border-white/10 rounded-md px-2.5 py-1 text-[11px] font-semibold text-white/40">{cert}</span>
        ))}
      </div>
    </div>
  </div>
</footer>
