---
import { footerLinks, compareLinks } from '../../data/navigation';
---
<footer class="bg-purple-dark text-white/70">
  <div class="container-site pt-[72px] pb-10">
    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12 mb-16">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-2.5 no-underline mb-4" aria-label="Stakater Cloud">
          <div class="w-8 h-8 bg-orange rounded-lg flex items-center justify-center">
            <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none">
              <path d="M12 2 2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <span class="text-[16px] font-bold text-white tracking-[-0.3px]">Stakater Cloud</span>
        </a>
        <p class="text-[14px] leading-relaxed text-white/50 max-w-[280px] mb-6">
          Managed OpenShift hosted in Europe. Operated by Red Hat Premier Partners. Production-ready in under 15 minutes.
        </p>
        <!-- Socials -->
        <div class="flex gap-3">
          {[
            { href: 'https://github.com/stakater', label: 'GitHub', icon: 'GH' },
            { href: 'https://www.linkedin.com/company/stakater', label: 'LinkedIn', icon: 'in' },
            { href: 'https://twitter.com/stakater', label: 'X / Twitter', icon: '𝕏' },
          ].map(s => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.label}
              class="w-9 h-9 rounded-lg bg-white/[0.08] flex items-center justify-center text-[13px] font-bold text-white/60 hover:bg-orange hover:text-white transition-all duration-150 no-underline"
            >
              {s.icon}
            </a>
          ))}
        </div>
      </div>

      <!-- Link Columns -->
      {Object.entries(footerLinks).map(([group, links]) => (
        <div>
          <h6 class="text-[11px] font-bold uppercase tracking-[1.5px] text-white/40 mb-5">{group}</h6>
          <ul class="list-none m-0 p-0 flex flex-col gap-2.5">
            {links.map(link => (
              <li>
                <a
                  href={link.href}
                  class="text-[14px] text-white/60 no-underline hover:text-orange transition-colors duration-150"
                  target={link.href.startsWith('http') ? '_blank' : undefined}
                  rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Compare row -->
    <div class="py-6 border-t border-white/8 border-b">
      <div class="flex items-center gap-4 flex-wrap">
        <span class="text-[12px] font-bold uppercase tracking-widest text-white/30">Compare</span>
        {compareLinks.map(l => (
          <a href={l.href} class="text-[13px] text-white/40 no-underline hover:text-orange transition-colors duration-150">{l.label}</a>
        ))}
      </div>
    </div>

    <!-- Bottom -->
    <div class="pt-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <div class="text-[12px] text-white/30 flex flex-wrap items-center gap-x-3 gap-y-1">
        <span>© {new Date().getFullYear()} Stakater Cloud · Stakater AB Sweden · Org # 559066-6870</span>
        <span class="hidden sm:inline text-white/15">·</span>
        <a href="/privacy" class="text-white/40 hover:text-orange transition-colors no-underline">Privacy Policy</a>
      </div>
      <div class="flex gap-2 flex-wrap">
        {['ISO 27001', 'ISO 9001', 'RH Premier Partner', 'GDPR Ready'].map(cert => (
          <span class="bg-white/[0.06] border border-white/10 rounded-md px-2.5 py-1 text-[11px] font-semibold text-white/40">{cert}</span>
        ))}
      </div>
    </div>
  </div>
</footer>
