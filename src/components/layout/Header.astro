---
import { nav } from '../../data/navigation';
import Button from '../ui/Button.astro';
---
<header class="sticky top-0 z-50 bg-bg-main/90 backdrop-blur-md border-b border-border">
  <nav class="container-site h-[68px] flex items-center justify-between gap-8">
    <!-- Logo -->
    <a href="/" class="flex items-center no-underline flex-shrink-0" aria-label="Stakater Cloud">
      <img src="/images/logo.svg" alt="Stakater Cloud" class="h-6 w-auto" />
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden lg:flex items-center gap-6 list-none m-0 p-0">
      {nav.map((item) => (
        <li class="relative group">
          {item.href ? (
            <a href={item.href} class="text-[14px] font-medium text-purple/75 hover:text-purple no-underline transition-colors duration-150">
              {item.label}
            </a>
          ) : (
            <>
              <button class="text-[14px] font-medium text-purple/75 hover:text-purple transition-colors duration-150 flex items-center gap-1">
                {item.label}
                <svg class="w-3 h-3 transition-transform duration-150 group-hover:rotate-180" fill="none" viewBox="0 0 12 12">
                  <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <div class="absolute top-full left-0 pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                {item.groups ? (
                  /* Multi-column grouped dropdown */
                  <div class="bg-white border border-border rounded-xl shadow-lg p-5 flex gap-8 min-w-[480px]">
                    {item.groups.map((group) => (
                      <div class="flex-1 min-w-0">
                        <div class="text-[10px] font-bold uppercase tracking-[1.5px] text-muted mb-3 px-1">{group.label}</div>
                        <div class="flex flex-col gap-0.5">
                          {group.items.map((child) => (
                            <a
                              href={child.href}
                              target={child.external ? '_blank' : undefined}
                              rel={child.external ? 'noopener noreferrer' : undefined}
                              class="flex flex-col gap-0.5 px-3 py-2.5 rounded-lg hover:bg-bg-main no-underline transition-colors duration-150 group/link"
                            >
                              <span class="text-[14px] font-semibold text-purple group-hover/link:text-orange transition-colors duration-150 whitespace-nowrap">{child.label}</span>
                              {child.description && (
                                <span class="text-[12px] text-muted leading-snug">{child.description}</span>
                              )}
                            </a>
                          ))}
                        </div>
                      </div>
                    ))}
                  </div>
                ) : (
                  /* Single-column dropdown */
                  <div class="bg-white border border-border rounded-xl shadow-lg p-2 min-w-[240px]">
                    {item.children?.map((child) => (
                      <a
                        href={child.href}
                        target={child.external ? '_blank' : undefined}
                        rel={child.external ? 'noopener noreferrer' : undefined}
                        class="flex flex-col gap-0.5 px-3 py-2.5 rounded-lg hover:bg-bg-main no-underline transition-colors duration-150 group/link"
                      >
                        <span class="text-[14px] font-semibold text-purple group-hover/link:text-orange transition-colors duration-150">{child.label}</span>
                        {child.description && (
                          <span class="text-[12px] text-muted leading-snug">{child.description}</span>
                        )}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            </>
          )}
        </li>
      ))}
    </ul>

    <!-- CTA -->
    <div class="flex items-center gap-3">
      <Button href="/contact" variant="nav">Book a Call →</Button>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden w-9 h-9 flex flex-col items-center justify-center gap-1.5 rounded-lg hover:bg-bg-alt transition-colors"
        aria-label="Toggle menu"
      >
        <span class="w-5 h-0.5 bg-purple transition-all duration-200 hamburger-line"></span>
        <span class="w-5 h-0.5 bg-purple transition-all duration-200 hamburger-line"></span>
        <span class="w-5 h-0.5 bg-purple transition-all duration-200 hamburger-line"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-border bg-white">
    <div class="container-site py-6 flex flex-col gap-1">
      {nav.map((item) => (
        <div>
          {item.href ? (
            <a href={item.href} class="block px-3 py-2.5 text-[15px] font-semibold text-purple no-underline hover:text-orange transition-colors">
              {item.label}
            </a>
          ) : (
            <>
              <span class="block px-3 py-1.5 text-[11px] font-bold uppercase tracking-widest text-muted mt-3 first:mt-0">{item.label}</span>
              {item.children?.map((child) => (
                <a href={child.href} target={child.external ? '_blank' : undefined} rel={child.external ? 'noopener noreferrer' : undefined} class="block px-3 py-2 text-[14px] font-medium text-purple/75 no-underline hover:text-orange transition-colors">
                  {child.label}
                </a>
              ))}
              {item.groups?.map((group) => (
                <>
                  <span class="block px-3 pt-2 pb-1 text-[10px] font-bold uppercase tracking-widest text-muted/60">{group.label}</span>
                  {group.items.map((child) => (
                    <a href={child.href} target={child.external ? '_blank' : undefined} rel={child.external ? 'noopener noreferrer' : undefined} class="block px-3 py-2 text-[14px] font-medium text-purple/75 no-underline hover:text-orange transition-colors">
                      {child.label}
                    </a>
                  ))}
                </>
              ))}
            </>
          )}
        </div>
      ))}
      <div class="pt-4 border-t border-border mt-2">
        <a href="/contact" class="btn-primary w-full justify-center">Book a Call →</a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
