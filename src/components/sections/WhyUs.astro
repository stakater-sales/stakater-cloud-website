---
import SectionLabel from '../ui/SectionLabel.astro';

const reasons = [
  {
    title: '100% EU Data Residency',
    desc: 'Your data never leaves Europe. Hosted in our Netherlands data center — fully compliant with GDPR, DORA and NIS2 out of the box.',
    svg: 'M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z',
  },
  {
    title: 'Start at the PaaS Layer',
    desc: 'Hyperscalers start at raw infrastructure. We start at the platform. No months of setup, no platform team needed, no assembly required.',
    svg: 'M3 6h18M3 11h18M3 16h18',
    stroke: true,
  },
  {
    title: 'Red Hat Premier Partner',
    desc: "We are Red Hat's Premier Partner and Container Management Specialists — the highest level of OpenShift expertise available in Europe.",
    svg: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
  },
  {
    title: 'Up to 40% Lower Cost',
    desc: 'Predictable monthly pricing. No egress fees, no surprise bills. Up to 40% cheaper than running OpenShift on AWS, Azure or GCP.',
    svg: 'M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6',
    stroke: true,
  },
  {
    title: 'Enterprise Security Built-In',
    desc: 'Hardened defaults, RHACS, certificate management, Vault for secrets, audit logging, RBAC — all configured and managed from day one.',
    svg: 'M12 3L4 7v5c0 5.1 3.4 9.8 8 11 4.6-1.2 8-5.9 8-11V7l-8-4z M9 12l2 2 4-4',
    stroke: true,
  },
  {
    title: 'Expert Day-2 Operations',
    desc: 'Our SRE team handles upgrades, incident response, capacity planning and architecture guidance — forever. No internal platform team required.',
    svg: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
    stroke: true,
  },
];
---
<section class="section-pad bg-bg-main" id="why">
  <div class="container-site">
    <div class="mb-[72px]">
      <SectionLabel>Why Stakater Cloud</SectionLabel>
      <h2 class="max-w-[560px] mb-4">Not just a cloud.<br />A complete platform.</h2>
      <p class="text-[17px] text-muted max-w-[520px]">AWS gives you building blocks. We give you a finished platform, managed by OpenShift experts.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {reasons.map(r => (
        <div class="card p-9 hover:border-orange transition-colors duration-200 animate-on-scroll">
          <div class="w-[52px] h-[52px] rounded-[14px] bg-bg-alt flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-orange" viewBox="0 0 24 24" fill={r.stroke ? 'none' : 'currentColor'} stroke={r.stroke ? 'currentColor' : 'none'} stroke-width={r.stroke ? '1.8' : '0'} stroke-linecap="round" stroke-linejoin="round">
              <path d={r.svg} />
            </svg>
          </div>
          <h5 class="text-[18px] text-purple mb-2.5">{r.title}</h5>
          <p class="text-[15px] text-muted leading-relaxed">{r.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
