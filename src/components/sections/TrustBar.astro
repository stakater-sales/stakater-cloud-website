---
---
<section class="bg-white border-b border-border py-10">
  <div class="container-site">
    <div class="flex items-center gap-12 flex-wrap">
      <span class="text-[12px] font-bold uppercase tracking-[1.5px] text-muted whitespace-nowrap flex-shrink-0">
        Trusted & Certified
      </span>
      <div class="w-px h-8 bg-border hidden md:block flex-shrink-0"></div>
      <div class="flex items-center gap-8 flex-wrap">
        <!-- Red Hat badge -->
        <div class="flex items-center gap-2.5 bg-[#EE0000] text-white px-4 py-2 rounded-lg">
          <svg class="w-4 h-4 fill-white flex-shrink-0" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>
          <span class="text-[13px] font-bold whitespace-nowrap">Red Hat Premier Partner</span>
        </div>
        {[
          { icon: '🏅', label: 'Container Management Specialist' },
          { icon: '🔒', label: 'ISO 27001 Certified' },
          { icon: '✅', label: 'ISO 9001 Certified' },
          { icon: '🇪🇺', label: 'GDPR · DORA · NIS2' },
        ].map(b => (
          <div class="flex items-center gap-2.5">
            <div class="w-9 h-9 rounded-lg bg-bg-alt flex items-center justify-center text-[18px] flex-shrink-0">{b.icon}</div>
            <span class="text-[14px] font-semibold text-purple whitespace-nowrap">{b.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
