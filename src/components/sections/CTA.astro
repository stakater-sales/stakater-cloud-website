---
import Button from '../ui/Button.astro';
import SectionLabel from '../ui/SectionLabel.astro';

interface Props {
  heading?: string;
  subheading?: string;
}

const {
  heading = 'Ready to stop managing infrastructure?',
  subheading = "Book a 30-minute call with our OpenShift experts. We'll scope the right solution for your team and have you up and running in days — not months.",
} = Astro.props;
---
<section class="bg-gradient-to-br from-orange to-orange-dark py-[100px]" id="cta">
  <div class="container-site text-center">
    <SectionLabel center class="text-white/70">Get Started</SectionLabel>
    <h2 class="text-white text-[48px] mb-4">{heading}</h2>
    <p class="text-white/80 text-[18px] mb-10 max-w-[560px] mx-auto">
      {subheading}
    </p>
    <div class="flex gap-4 justify-center flex-wrap">
      <Button href="/contact" variant="white">Book a Call →</Button>
      <Button href="/pricing" variant="ghost-white">View Pricing</Button>
    </div>
  </div>
</section>
