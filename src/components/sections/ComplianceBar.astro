---
const badges = ['GDPR', 'DORA', 'NIS2', 'ISO 27001', 'ISO 9001', 'Netherlands DC'];
---
<section class="bg-white py-20 border-t border-border">
  <div class="container-site">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <div>
        <h4 class="text-[22px] mb-2">Built for European compliance</h4>
        <p class="text-[15px] text-muted max-w-[400px]">
          Every cluster is hosted in the Netherlands. Your data never leaves Europe. Our platform meets GDPR, DORA, NIS2, ISO 27001 and ISO 9001 requirements from day one.
        </p>
      </div>
      <div class="flex gap-3 flex-wrap">
        {badges.map(b => (
          <div class="bg-bg-alt border border-border rounded-xl px-5 py-3 text-[13px] font-bold text-purple whitespace-nowrap">{b}</div>
        ))}
      </div>
    </div>
  </div>
</section>
