---
import Button from '../ui/Button.astro';
import Badge from '../ui/Badge.astro';
---
<section class="relative bg-gradient-to-br from-purple to-purple-dark overflow-hidden pt-[120px] pb-[100px]">
  <!-- Background glow -->
  <div class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full bg-[radial-gradient(circle,rgba(255,86,35,0.15)_0%,transparent_70%)] pointer-events-none"></div>
  <div class="absolute -bottom-24 left-1/3 w-[400px] h-[400px] rounded-full bg-[radial-gradient(circle,rgba(255,86,35,0.08)_0%,transparent_70%)] pointer-events-none"></div>

  <div class="container-site relative z-10">
    <!-- Badge -->
    <div class="mb-8">
      <span class="inline-flex items-center gap-2 bg-orange/15 border border-orange/40 text-orange-light text-[13px] font-semibold px-4 py-1.5 rounded-full tracking-[0.3px]">
        <span class="w-1.5 h-1.5 rounded-full bg-orange animate-pulse-dot"></span>
        Red Hat Premier Partner · Netherlands Data Center
      </span>
    </div>

    <!-- Headline -->
    <h1 class="text-white max-w-[860px] mb-6">
      Managed OpenShift,<br />
      <span class="text-orange">Ready in 15 Minutes.</span><br />
      Hosted in Europe.
    </h1>

    <!-- Sub -->
    <p class="text-[20px] leading-relaxed text-white/70 max-w-[600px] mb-12">
      Stop assembling infrastructure from scratch. Stakater Cloud delivers a fully managed, production-ready OpenShift platform — with everything pre-wired and operated by experts. You ship. We run the platform.
    </p>

    <!-- CTAs -->
    <div class="flex gap-4 items-center flex-wrap mb-20">
      <Button href="/contact" variant="primary">Book a Call →</Button>
      <Button href="/products" variant="ghost-white">Explore Products</Button>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-3 max-w-[680px] rounded-2xl overflow-hidden border border-white/10 bg-white/5">
      {[
        { num: '< 15', unit: 'min', label: 'Production cluster ready' },
        { num: '40', unit: '%', label: 'Lower cost vs hyperscalers' },
        { num: '100', unit: '%', label: 'EU data residency' },
      ].map((s, i) => (
        <div class={`px-8 py-7 bg-white/[0.04] ${i < 2 ? 'border-b sm:border-b-0 sm:border-r border-white/10' : ''}`}>
          <div class="text-[36px] font-bold text-white leading-none tracking-[-1px] mb-1">
            {s.num}<span class="text-orange">{s.unit}</span>
          </div>
          <div class="text-[14px] text-white/55 font-medium">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
