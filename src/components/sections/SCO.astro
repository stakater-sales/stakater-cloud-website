---
import SectionLabel from '../ui/SectionLabel.astro';
import Button from '../ui/Button.astro';

const capabilities = [
  {
    title: 'Multi-tenant cluster orchestration',
    desc: 'Provision, manage and decommission clusters across your customer base from a single control plane. Full lifecycle automation, no manual ops.',
    icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z',
  },
  {
    title: 'White-label customer portal',
    desc: 'Your brand, your domain. Give your customers a self-service portal to provision and manage their own clusters — without them knowing what runs underneath.',
    icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
  },
  {
    title: 'Sovereign deployment',
    desc: "Runs entirely in your own infrastructure — your data center, your cloud region, your jurisdiction. No dependency on Stakater's infrastructure.",
    icon: 'M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3',
  },
  {
    title: 'Billing & metering built in',
    desc: 'Charge your customers per cluster, per node, or on custom plans. Usage metering, invoice generation and payment integration are part of the platform.',
    icon: 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z',
  },
  {
    title: 'Add-on marketplace',
    desc: 'Let customers self-service managed add-ons — PostgreSQL, Redis, RabbitMQ, observability stacks — from a curated catalog you control.',
    icon: 'M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10',
  },
  {
    title: 'Policy & compliance engine',
    desc: 'Enforce cluster policies, network isolation, RBAC boundaries and compliance controls centrally. Audit logs and reports generated automatically.',
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  },
];

const personas = [
  { label: 'MSPs', desc: 'Offer managed OpenShift to your enterprise clients under your own brand — without building the orchestration layer yourself.' },
  { label: 'CSPs', desc: 'Add a sovereign managed Kubernetes tier to your cloud catalog. Differentiate on compliance and EU data residency.' },
  { label: 'Telcos', desc: 'Deliver managed cloud services to enterprise customers on your own infrastructure. Full white-label, full data sovereignty.' },
];
---
<section class="section-pad bg-bg-alt" id="sco">
  <div class="container-site">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-start mb-[72px]">

      <!-- Left: positioning -->
      <div>
        <SectionLabel>Stakater Cloud Orchestrator</SectionLabel>
        <h2 class="mb-6">The sovereign XaaS platform.<br />Run your own managed cloud.</h2>
        <p class="text-[17px] text-muted leading-relaxed mb-6">
          Stakater Cloud Orchestrator (SCO) is the platform that powers Stakater Cloud. It is a sovereign, white-label XaaS enabler — purpose-built for MSPs, CSPs and Telcos who want to offer managed OpenShift services to their own customers, without building the orchestration layer from scratch.
        </p>
        <p class="text-[17px] text-muted leading-relaxed mb-10">
          Stakater Cloud is our own deployment of SCO. We run it in production, we depend on it, and every capability we ship to our own customers is built on it. When you buy SCO, you get the same platform — deployed in your infrastructure, under your brand, in your jurisdiction.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <Button href="/contact" variant="primary">Talk to Us About SCO →</Button>
        </div>
      </div>

      <!-- Right: dog-fooding callout + personas -->
      <div class="flex flex-col gap-6">

        <!-- Dog-fooding badge -->
        <div class="rounded-2xl border-2 border-orange/30 bg-orange/5 p-8">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-orange flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
              </svg>
            </div>
            <div>
              <p class="text-[13px] font-bold uppercase tracking-[1.5px] text-orange mb-1">Production-proven</p>
              <h5 class="text-purple text-[17px] font-bold mb-2">Stakater Cloud is built on SCO</h5>
              <p class="text-[14px] text-muted leading-relaxed">
                We do not sell software we do not run ourselves. Stakater Cloud is our own SCO deployment — every feature, every API, every portal capability is dog-fooded by our own SRE team before it reaches you.
              </p>
            </div>
          </div>
        </div>

        <!-- Personas -->
        <div class="flex flex-col gap-4">
          {personas.map(p => (
            <div class="card p-6 flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-purple/10 flex items-center justify-center flex-shrink-0">
                <span class="text-[13px] font-bold text-purple">{p.label}</span>
              </div>
              <p class="text-[14px] text-muted leading-relaxed">{p.desc}</p>
            </div>
          ))}
        </div>

      </div>
    </div>

    <!-- Capabilities grid -->
    <div>
      <p class="text-[13px] font-bold uppercase tracking-[2px] text-muted mb-8 text-center">What SCO gives you</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {capabilities.map(c => (
          <div class="card p-8 animate-on-scroll">
            <div class="w-11 h-11 rounded-[14px] bg-purple/10 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-purple" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d={c.icon} />
              </svg>
            </div>
            <h5 class="text-[16px] text-purple mb-2">{c.title}</h5>
            <p class="text-[14px] text-muted leading-relaxed">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
