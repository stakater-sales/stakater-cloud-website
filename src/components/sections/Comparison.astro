---
import SectionLabel from '../ui/SectionLabel.astro';

const rows = [
  { feature: 'Managed OpenShift cluster',       stakater: true,      rosa: true,          diy: false },
  { feature: 'EU data residency',               stakater: true,      rosa: 'Partial',     diy: 'Partial' },
  { feature: 'GitOps pre-configured (ArgoCD)',  stakater: true,      rosa: false,         diy: false },
  { feature: 'CI/CD pre-configured (Tekton)',   stakater: true,      rosa: false,         diy: false },
  { feature: 'Secrets management (OpenBao)',       stakater: true,      rosa: false,         diy: false },
  { feature: 'Multi-tenancy (MTO)',              stakater: true,      rosa: false,         diy: false },
  { feature: 'Full observability (monitoring, logging, tracing, alerting)',        stakater: true,      rosa: 'Basic',       diy: false },
  { feature: 'No hyperscaler lock-in',           stakater: true,      rosa: false,         diy: false },
  { feature: 'Predictable EU pricing',           stakater: true,      rosa: 'Partial',     diy: false },
  { feature: 'Time to first workload',           stakater: '< 15 min', rosa: 'Days–weeks', diy: 'Months' },
];

function cell(val: boolean | string) {
  if (val === true) return { text: '✓', cls: 'text-green-600 text-[18px]' };
  if (val === false) return { text: '✗', cls: 'text-red-500 text-[18px]' };
  return { text: val, cls: 'text-amber-600 text-[13px] font-semibold' };
}
---
<section class="section-pad bg-white" id="compare">
  <div class="container-site">
    <div class="text-center max-w-[680px] mx-auto mb-[72px]">
      <SectionLabel center>Comparison</SectionLabel>
      <h2 class="mb-4">Stakater Cloud vs the alternatives</h2>
      <p class="text-muted text-[17px]">The real alternative isn't AWS, Azure or GCP — it's spending 12–18 months building this yourself with an internal platform team.</p>
    </div>
    <div class="rounded-2xl overflow-hidden border border-border bg-bg-main">
      <table class="w-full border-collapse">
        <thead>
          <tr>
            <th class="text-left px-7 py-5 text-[14px] font-bold bg-white border-b border-border w-[35%]">Feature</th>
            <th class="px-7 py-5 text-[14px] font-bold bg-purple text-white border-b border-purple/50 text-center">Stakater Cloud</th>
            <th class="px-7 py-5 text-[14px] font-bold bg-white border-b border-border text-center text-muted">ROSA / ARO</th>
            <th class="px-7 py-5 text-[14px] font-bold bg-white border-b border-border text-center text-muted">DIY on AWS / Azure / GCP</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row, i) => {
            const sc = cell(row.stakater);
            const ro = cell(row.rosa);
            const di = cell(row.diy);
            return (
              <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bg-main/50'}>
                <td class="px-7 py-[18px] text-[15px] font-medium text-black border-b border-border">{row.feature}</td>
                <td class={`px-7 py-[18px] border-b border-purple/10 text-center bg-purple/[0.03] font-bold text-purple ${sc.cls}`}>{sc.text}</td>
                <td class={`px-7 py-[18px] border-b border-border text-center ${ro.cls}`}>{ro.text}</td>
                <td class={`px-7 py-[18px] border-b border-border text-center ${di.cls}`}>{di.text}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </div>
</section>
