---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/ui/SectionLabel.astro';
import CTA from '../components/sections/CTA.astro';

const faqs = [
  {
    category: 'Product',
    items: [
      { q: 'What exactly is Managed OpenShift?', a: 'A dedicated OpenShift cluster provisioned exclusively for your organisation, hosted in our Netherlands data center. Stakater manages all upgrades, lifecycle operations, and platform health. You get a cluster — we run it.' },
      { q: 'What is SAAP?', a: 'SAAP (Stakater App Agility Platform) is Managed OpenShift plus a complete, pre-integrated developer platform — GitOps with ArgoCD, CI/CD with Tekton, secrets with OpenBao, multi-tenancy with MTO, full observability (monitoring, logging, tracing, alerting), backup, and a developer portal with Backstage. All managed by Stakater.' },
      { q: 'Can I start with Managed OpenShift and add SAAP later?', a: 'Yes. You can start with just the managed cluster and add the full SAAP platform at any time. Contact us to discuss the upgrade path.' },
      { q: 'How long does provisioning take?', a: 'Your cluster is provisioned in under 15 minutes. The full onboarding call and configuration discussion typically takes 30 minutes before that.' },
    ],
  },
  {
    category: 'Infrastructure & Compliance',
    items: [
      { q: 'Where is my data hosted?', a: 'All clusters are hosted exclusively in our Netherlands data center. Your data never leaves Europe and is never processed by US-jurisdiction infrastructure.' },
      { q: 'Is Stakater Cloud GDPR compliant?', a: 'Yes. Our infrastructure is designed to support GDPR compliance. We offer Data Processing Agreements (DPAs) and all processing occurs within the EU.' },
      { q: 'What about DORA and NIS2?', a: 'Our infrastructure and operations are aligned to DORA requirements for financial services and NIS2 for critical infrastructure organisations. Contact us for a detailed compliance discussion.' },
      { q: 'What certifications do you hold?', a: 'We are certified to ISO 27001:2022 (information security management) and ISO 9001:2015 (quality management). Both certifications are audited annually.' },
    ],
  },
  {
    category: 'Pricing & Commercial',
    items: [
      { q: 'Is the Red Hat subscription included?', a: 'Yes. The Red Hat OpenShift subscription is included in your Stakater Cloud pricing. There is no separate Red Hat bill.' },
      { q: 'Are there egress fees?', a: 'No. We do not charge egress fees. Your monthly subscription is the total cost.' },
      { q: 'What is the minimum commitment?', a: 'We offer monthly and annual subscriptions. Annual subscriptions come with a discount. Contact us to discuss what works for your organisation.' },
      { q: 'Can I scale my cluster?', a: 'Yes. You can add nodes or change node sizes at any time. Changes are applied by our SRE team with zero downtime.' },
    ],
  },
  {
    category: 'Operations & Support',
    items: [
      { q: 'What does Stakater manage day-to-day?', a: 'Stakater SRE manages all cluster upgrades, patch management, incident response, capacity planning, and platform health monitoring. You never need to think about platform operations.' },
      { q: 'What support options are available?', a: 'Standard support (8/5, ticket-based) is included with all plans. Premium support (24/7, phone + ticket, priority queue, named technical contact) is available for an additional €2,000/month.' },
      { q: 'What happens if I want to leave?', a: 'You own your data and workloads. We will help you migrate out cleanly. OpenShift is a standard platform — your applications are not locked into proprietary APIs.' },
      { q: 'Do I need my own platform team?', a: 'No. That is the point. Stakater Cloud is designed so you do not need internal platform engineers. Our SRE team is your platform team.' },
    ],
  },
];
---
<BaseLayout
  title="FAQ"
  description="Frequently asked questions about Stakater Cloud — Managed OpenShift, SAAP, pricing, compliance, and operations."
>
  <section class="section-pad bg-bg-main">
    <div class="container-site">
      <div class="text-center max-w-[600px] mx-auto mb-[72px]">
        <SectionLabel center>FAQ</SectionLabel>
        <h1 class="mb-4">Frequently Asked Questions</h1>
        <p class="text-muted text-[18px]">Everything you need to know before booking a call.</p>
      </div>

      <div class="max-w-[800px] mx-auto flex flex-col gap-16">
        {faqs.map(section => (
          <div>
            <h3 class="text-[24px] mb-8 pb-4 border-b border-border">{section.category}</h3>
            <div class="flex flex-col gap-4">
              {section.items.map(faq => (
                <details class="card p-6 group cursor-pointer">
                  <summary class="flex justify-between items-center text-[16px] font-semibold text-purple list-none gap-4">
                    {faq.q}
                    <span class="text-orange text-[22px] leading-none flex-shrink-0 group-open:rotate-45 transition-transform duration-200">+</span>
                  </summary>
                  <p class="text-[15px] text-muted leading-relaxed mt-4 pt-4 border-t border-border">{faq.a}</p>
                </details>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
  <CTA />
</BaseLayout>
