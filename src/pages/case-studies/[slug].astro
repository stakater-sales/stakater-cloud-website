---
export const prerender = true;
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionLabel from '../../components/ui/SectionLabel.astro';
import Button from '../../components/ui/Button.astro';
import CTA from '../../components/sections/CTA.astro';

export async function getStaticPaths() {
  const studies = await getCollection('case-studies');
  return studies.map(study => ({ params: { slug: study.slug }, props: { study } }));
}

const { study } = Astro.props;
const { Content } = await study.render();

const iconPaths: Record<string, string> = {
  savings:  'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  award:    'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z',
  speed:    'M13 10V3L4 14h7v7l9-11h-7z',
  users:    'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
  server:   'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01',
  shield:   'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  globe:    'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  layers:   'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5',
  check:    'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  star:     'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z',
  clock:    'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
};

const fallbackIcon = iconPaths.check;
---

<BaseLayout
  title={`${study.data.company} — Case Study`}
  description={study.data.challenge}
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-purple to-purple-dark pt-[100px] pb-[80px]">
    <div class="container-site">
      <SectionLabel white>Case Study</SectionLabel>
      <div class="flex items-center gap-3 mb-6 flex-wrap">
        <span class="inline-flex items-center gap-1.5 bg-orange/20 border border-orange/40 text-orange-light text-[12px] font-bold px-3 py-1 rounded-full tracking-wide uppercase">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          {study.data.industry}
        </span>
      </div>
      <h1 class="text-white max-w-[800px] mb-6">{study.data.company}</h1>
      <p class="text-[20px] text-white/70 max-w-[640px]">{study.data.challenge}</p>
    </div>
  </section>

  <!-- Metrics bar -->
  {study.data.metrics.length > 0 && (
    <section class="bg-white border-b border-border">
      <div class="container-site py-12">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {study.data.metrics.map((m, i) => (
            <div class="flex flex-col gap-3">
              <div class="w-10 h-10 rounded-xl bg-orange/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d={iconPaths[m.icon ?? ''] ?? fallbackIcon} />
                </svg>
              </div>
              <div>
                <div class="text-[36px] font-bold text-purple tracking-tight leading-none mb-1.5">{m.value}</div>
                <div class="text-[13px] text-muted">{m.label}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Body + sidebar -->
  <section class="section-pad bg-bg-main">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-16 items-start">
        <article class="prose prose-lg max-w-none
          prose-headings:text-purple prose-headings:font-bold
          prose-p:text-muted prose-p:leading-relaxed
          prose-a:text-orange prose-a:no-underline hover:prose-a:underline
          prose-strong:text-purple
          prose-li:text-muted
          prose-hr:border-border">
          <Content />
        </article>

        <aside class="sticky top-[100px] flex flex-col gap-5">
          <div class="card p-8">
            <h6 class="text-[15px] font-bold text-purple mb-6">About this case study</h6>
            <div class="flex flex-col gap-5 text-[14px]">

              <div class="flex gap-3">
                <div class="w-8 h-8 rounded-lg bg-orange/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div>
                  <div class="text-muted mb-0.5">Industry</div>
                  <div class="font-semibold text-purple">{study.data.industry}</div>
                </div>
              </div>

              <div class="flex gap-3">
                <div class="w-8 h-8 rounded-lg bg-orange/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                  </svg>
                </div>
                <div>
                  <div class="text-muted mb-0.5">Outcome</div>
                  <div class="font-semibold text-purple leading-snug">{study.data.outcome}</div>
                </div>
              </div>

              {study.data.services.length > 0 && (
                <div class="flex gap-3">
                  <div class="w-8 h-8 rounded-lg bg-orange/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                    <svg class="w-4 h-4 text-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"/>
                    </svg>
                  </div>
                  <div>
                    <div class="text-muted mb-2">Services Used</div>
                    <div class="flex flex-col gap-2">
                      {study.data.services.map(s => (
                        <span class="inline-block w-fit bg-orange/10 text-orange border border-orange/20 text-[12px] font-semibold px-3 py-1 rounded-full">
                          {s}
                        </span>
                      ))}
                    </div>
                  </div>
                </div>
              )}

            </div>
            <div class="mt-8 pt-8 border-t border-border">
              <Button href="/contact" variant="primary" class="w-full justify-center">Book a Call →</Button>
            </div>
          </div>

          <a href="/case-studies" class="flex items-center gap-2 text-[14px] text-muted hover:text-orange transition-colors no-underline">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
            All case studies
          </a>
        </aside>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
