---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
---
<BaseLayout title="Page Not Found" noindex={true}>
  <section class="section-pad bg-bg-main min-h-[60vh] flex items-center">
    <div class="container-site text-center max-w-[560px] mx-auto">
      <div class="text-[96px] font-bold text-orange/20 leading-none mb-8">404</div>
      <h1 class="mb-4">Page not found</h1>
      <p class="text-[18px] text-muted mb-10">The page you're looking for doesn't exist. It may have moved or been removed.</p>
      <div class="flex gap-4 justify-center flex-wrap">
        <Button href="/" variant="primary">Back to Home →</Button>
        <Button href="/contact" variant="ghost">Book a Call</Button>
      </div>
    </div>
  </section>
</BaseLayout>
