const { competitor, fullName, metaDescription, heroHeadline, heroSubline, clusterType, whatIsCompetitor, threeReasons, faqs } = Astro.props;
---

<BaseLayout title={`Stakater Cloud vs ${competitor}`} description={metaDescription}>

  <!-- HERO -->
  <section class="bg-gradient-to-br from-[#1A0D32] to-[#0A0614] pt-[100px] pb-[88px]">
    <div class="container-site">
      <div class="max-w-[800px]">
        <div class="inline-flex items-center gap-2 bg-white/[0.08] border border-white/10 rounded-full px-4 py-2 mb-8">
          <span class="w-1.5 h-1.5 bg-orange rounded-full"></span>
          <span class="text-[12px] font-bold uppercase tracking-widest text-white/50">Stakater Cloud vs {competitor}</span>
        </div>
        <h1 class="text-white mb-6">{heroHeadline}</h1>
        <p class="text-white/70 text-[20px] leading-relaxed mb-10 max-w-[680px]">{heroSubline}</p>

        <!-- Stat pills -->
        <div class="flex flex-wrap gap-4 mb-10">
          {[
            { stat: '< 15 min', label: 'to production' },
            { stat: '100% EU', label: 'data residency' },
            { stat: 'Zero', label: 'platform team needed' },
            { stat: '€888/mo', label: 'starting price' },
          ].map(s => (
            <div class="bg-white/[0.06] border border-white/[0.12] rounded-xl px-5 py-3">
              <div class="text-orange text-[22px] font-bold leading-none">{s.stat}</div>
              <div class="text-white/45 text-[12px] mt-1">{s.label}</div>
            </div>
          ))}
        </div>

        <div class="flex flex-wrap gap-4">
          <a href="/contact" class="btn-primary">Book a Call →</a>
          <a href="#compare" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-white/20 text-white/70 text-[15px] font-semibold hover:border-white/40 hover:text-white transition-all duration-150 no-underline">
            See comparison
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 9l-7 7-7-7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- THREE REASONS TO SWITCH -->
  <section class="section-pad bg-bg-alt">
    <div class="container-site">
      <div class="mb-[64px]">
        <SectionLabel>Why teams switch</SectionLabel>
        <h2 class="mt-3 max-w-[600px]">3 reasons teams move from {competitor} to Stakater Cloud</h2>
      </div>
      <div class="flex flex-col gap-6">
        {threeReasons.map((reason, i) => (
          <div class="card border-l-4 border-orange p-8 flex gap-6 animate-on-scroll" style={`transition-delay: ${i * 80}ms`}>
            <div class="w-12 h-12 flex-shrink-0 bg-orange/10 rounded-xl flex items-center justify-center mt-0.5">
              <svg class="w-6 h-6 text-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d={reason.icon} />
              </svg>
            </div>
            <div>
              <div class="text-[11px] font-bold uppercase tracking-widest text-orange mb-2">Reason {i + 1}</div>
              <h4 class="text-purple mb-3">{reason.title}</h4>
              <p class="text-muted text-[15px] leading-relaxed">{reason.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHAT IS + PLATFORM STACK VISUAL -->
  <section class="section-pad bg-white">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <!-- Left: Competitor explanation + stack visual -->
        <div class="animate-on-scroll">
          <SectionLabel>About {competitor}</SectionLabel>
          <h3 class="mt-3 mb-5">What is {fullName}?</h3>
          <p class="text-muted text-[16px] leading-relaxed mb-10">{whatIsCompetitor}</p>

          <!-- Platform stack visual -->
          <div>
            <p class="text-[13px] font-bold text-muted uppercase tracking-wider mb-4">Where each product starts and stops</p>
            <div class="grid grid-cols-2 gap-4">

              <!-- Competitor stack -->
              <div>
                <div class="text-center text-[13px] font-bold text-muted mb-3">{competitor}</div>
                <div class="rounded-xl overflow-hidden border border-border">
                  <div class="bg-red-50 border-b border-red-100 p-4">
                    <div class="flex items-center justify-between mb-2">
                      <span class="text-[12px] font-bold text-red-600">Platform Layer</span>
                      <span class="bg-red-100 text-red-500 text-[10px] font-bold px-2 py-0.5 rounded-full">Your team</span>
                    </div>
                    <div class="text-[11px] text-red-400 leading-relaxed">GitOps · CI/CD · Secrets<br/>Observability · Multi-tenancy</div>
                  </div>
                  <div class="bg-white border-b border-border px-4 py-3">
                    <div class="flex items-center gap-2">
                      <span class="text-green-500 text-[13px] font-bold">✓</span>
                      <span class="text-[12px] font-semibold text-purple">{clusterType}</span>
                    </div>
                  </div>
                  <div class="bg-bg-main px-4 py-3">
                    <div class="flex items-center gap-2">
                      <span class="text-green-500 text-[13px] font-bold">✓</span>
                      <span class="text-[12px] font-semibold text-purple">Cloud Infrastructure</span>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Stakater stack -->
