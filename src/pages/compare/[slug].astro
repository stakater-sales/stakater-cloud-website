---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import ComparisonTable from '../../components/sections/ComparisonTable.astro';
import CTA from '../../components/sections/CTA.astro';
import SectionLabel from '../../components/ui/SectionLabel.astro';

interface Reason {
  title: string;
  body: string;
  icon: string;
}
interface FAQ {
  q: string;
  a: string;
}

export function getStaticPaths() {
  return [
    {
      params: { slug: 'rosa-alternative' },
      props: {
        competitor: 'ROSA',
        fullName: 'Red Hat OpenShift Service on AWS (ROSA)',
        metaDescription: 'Stakater Cloud vs ROSA — managed OpenShift with EU data residency, full developer platform included, and no AWS lock-in. Compare features, pricing and compliance.',
        heroHeadline: 'Same OpenShift. Full platform. EU-operated.',
        heroSubline: 'ROSA manages your OpenShift cluster on AWS. Stakater Cloud adds GitOps, CI/CD, secrets, full observability and multi-tenancy — hosted in the Netherlands, operated by a Red Hat Premier Partner.',
        clusterType: 'Managed OpenShift (AWS)',
        whatIsCompetitor: "ROSA is Red Hat's managed OpenShift offering running on AWS infrastructure. It handles the OpenShift control plane well — but data defaults to AWS, the platform tooling above OpenShift is not included, and you inherit AWS pricing variability and US jurisdiction concerns.",
        threeReasons: [
          {
            title: 'Unambiguous EU data residency',
            body: 'ROSA runs on AWS — a US company subject to the US CLOUD Act. Stakater Cloud is operated by Stakater AB (Sweden) with all data hosted exclusively in our Netherlands data center. No US parent, no ambiguity for GDPR, DORA or NIS2 compliance.',
            icon: 'M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9',
          },
          {
            title: 'Full developer platform, not just the cluster',
            body: 'ROSA gives you a managed OpenShift cluster. Stakater Cloud gives you a managed platform: ArgoCD, Tekton, OpenBao, Prometheus, Grafana, Loki, Jaeger, multi-tenancy (MTO), Velero — all pre-configured, all managed by us. No platform team required.',
            icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z',
          },
          {
            title: 'Predictable flat pricing, no AWS bill',
            body: 'ROSA pricing combines EC2 instance costs, Red Hat OpenShift licensing, and every add-on your platform needs. Stakater Cloud is a flat monthly subscription from €888/month — no per-resource charges, no surprise data transfer fees, no AWS account to manage.',
