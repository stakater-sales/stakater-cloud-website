            icon: 'M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9',
          },
        ] as Reason[],
        faqs: [
          {
            q: 'Is AKS the same as OpenShift?',
